{
  "name": "websculpt",
  "version": "0.0.1",
  "description": "WebSculpt CLI",
  "type": "module",
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "websculpt": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc; npm run copy:commands",
    "copy:commands": "node -e \"require('fs').cpSync('src/cli/builtin', 'dist/cli/builtin', {recursive:true, force:true})\"",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest",
    "check": "biome check --write --error-on-warnings .",
    "format": "biome format --write .",
    "prepublishOnly": "npm run build; npm run check; npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/websculpt.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
