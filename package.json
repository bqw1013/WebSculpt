{
  "name": "websculpt",
  "version": "0.0.1",
  "description": "WebSculpt CLI",
  "type": "module",
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "websculpt": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && npm run copy:commands",
    "copy:commands": "node --input-type=module -e \"import fs from 'node:fs'; fs.cpSync('src/cli/builtin', 'dist/cli/builtin', {recursive:true, force:true})\"",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "biome check --error-on-warnings .",
    "check:fix": "biome check --write --error-on-warnings .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "sync-skills": "node scripts/sync-skills.js",
    "prepublishOnly": "npm run build && npm run check && npm run typecheck && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/websculpt.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@playwright/cli": "^0.1.8",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ws": "^8.18.3"
  },
  "peerDependencies": {
    "@playwright/cli": "^0.1.8"
  }
}
