{
  "name": "websculpt",
  "version": "0.1.2",
  "description": "WebSculpt CLI",
  "type": "module",
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "websculpt": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist', {recursive:true, force:true})\"",
    "build": "npm run clean && tsc && npm run copy:commands",
    "copy:commands": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist/cli/builtin', {recursive:true, force:true}); fs.cpSync('src/cli/builtin', 'dist/cli/builtin', {recursive:true, force:true})\"",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "biome check --error-on-warnings .",
    "check:fix": "biome check --write --error-on-warnings .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "verify:i18n": "node scripts/verify-i18n.js",
    "prepublishOnly": "npm run build && npm run check && npm run typecheck && npm run test && npm run verify:i18n"
  },
  "keywords": [
    "cli",
    "agent",
    "web",
    "browser",
    "automation",
    "scraping",
    "framework",
    "self-healing"
  ],
  "author": "bqw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bqw1013/websculpt.git"
  },
  "bugs": {
    "url": "https://github.com/bqw1013/websculpt/issues"
  },
  "homepage": "https://github.com/bqw1013/websculpt#readme",
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "playwright-core": "^1.60.0-alpha-2026-04-14",
    "ws": "^8.18.3"
  }
}
